import type { Context, Config } from "@netlify/functions";

/**
 * Integration Hub — Prepares and routes pipeline data to external systems.
 * Currently stubbed for Wrike and McKinsey WAVE.
 *
 * When endpoints become available:
 * 1. Set env vars: WRIKE_API_TOKEN, WRIKE_BASE_URL, WAVE_API_KEY, WAVE_BASE_URL
 * 2. Uncomment the actual API call blocks below
 * 3. Redeploy
 */

// ─── Types ──────────────────────────────────────────────────────────────────

interface PipelineData {
  id?: string;
  intake: string;
  refined?: string;
  prd?: string;
  tech_spec?: string;
  estimate?: string;
  proto_prompt?: string;
  build_status?: string;
  current_stage: number;
}

interface IntegrationRequest {
  target: "wrike" | "wave" | "jellyfish" | "status";
  action: string;
  pipeline: PipelineData;
}

interface IntegrationStatus {
  wrike:     { configured: boolean; connected: boolean; base_url: string | null };
  wave:      { configured: boolean; connected: boolean; base_url: string | null };
  jellyfish: { configured: boolean; connected: boolean; base_url: string | null };
}

// ─── Wrike Payload Builders ─────────────────────────────────────────────────

/**
 * Maps pipeline data to Wrike project/task structure.
 * Wrike API docs: https://developers.wrike.com/api/v4/
 *
 * Expected Wrike env vars:
 *   WRIKE_API_TOKEN  — OAuth2 permanent token or bearer token
 *   WRIKE_BASE_URL   — e.g., https://www.wrike.com/api/v4 (default)
 *   WRIKE_FOLDER_ID  — (optional) parent folder to create projects in
 */
function buildWrikeProject(pipeline: PipelineData) {
  const projectTitle = pipeline.intake.split("\n")[0].slice(0, 80) || "Product Forge Pipeline";
  return {
    // POST /folders/{folderId}/folders  — creates a project
    create_project: {
      title: projectTitle,
      description: `Generated by Product Forge AI\n\nOriginal Intake:\n${pipeline.intake}`,
      project: {
        status: "Green",
        startDate: new Date().toISOString().split("T")[0],
      },
      customFields: [],
      metadata: [{ key: "source", value: "product-forge-ai" }],
    },
    // POST /folders/{projectId}/tasks  — creates tasks from pipeline stages
    tasks: [
      ...(pipeline.refined ? [{
        title: "Refined Product Definition",
        description: pipeline.refined,
        status: "Completed",
        importance: "High",
      }] : []),
      ...(pipeline.prd ? [{
        title: "Product Requirements Document (PRD)",
        description: pipeline.prd,
        status: "Completed",
        importance: "High",
      }] : []),
      ...(pipeline.tech_spec ? [{
        title: "Technical Specification",
        description: pipeline.tech_spec,
        status: "Completed",
        importance: "High",
      }] : []),
      ...(pipeline.estimate ? [{
        title: "Cost & Timeline Estimate",
        description: pipeline.estimate,
        status: "Completed",
        importance: "High",
      }] : []),
      // Placeholder follow-up tasks
      { title: "Review & Approve PRD", status: "Active", importance: "High" },
      { title: "Vendor/Team Selection", status: "Active", importance: "Normal" },
      { title: "Kick-off Meeting", status: "Deferred", importance: "Normal" },
    ],
  };
}

