// ─── McKinsey WAVE Payload Builders ─────────────────────────────────────────

/**
 * Maps pipeline data to McKinsey WAVE initiative structure.
 * WAVE is used for value creation planning and transformation tracking.
 *
 * Expected WAVE env vars:
 *   WAVE_API_KEY    — API key or OAuth token
 *   WAVE_BASE_URL   — WAVE API endpoint (to be provided by McKinsey)
 *   WAVE_PROGRAM_ID — (optional) parent program/portfolio ID
 *
 * NOTE: WAVE API schema is assumed based on typical transformation
 * management platforms. Adjust field mappings when actual API docs are available.
 */
function buildWaveInitiative(pipeline: PipelineData) {
  const initiativeName = pipeline.intake.split("\n")[0].slice(0, 80) || "Product Forge Initiative";

  // Extract cost estimates from the estimate text if available
  const estimateText = pipeline.estimate || "";
  const costMatch = estimateText.match(/\$[\d,.]+[KkMm]?\s*[-–]\s*\$[\d,.]+[KkMm]?/);
  const timelineMatch = estimateText.match(/(\d+)\s*[-–]\s*(\d+)\s*weeks/i);

  return {
    // Initiative creation payload
    initiative: {
      name: initiativeName,
      description: pipeline.refined || pipeline.intake,
      source: "product-forge-ai",
      status: pipeline.current_stage >= 5 ? "ready_for_review" : "in_development",
      category: "digital_transformation",
      created_date: new Date().toISOString(),
    },
    // Value drivers / business case
    business_case: {
      problem_statement: pipeline.intake,
      refined_scope: pipeline.refined || null,
      requirements_summary: pipeline.prd || null,
      technical_approach: pipeline.tech_spec || null,
      cost_estimate_raw: pipeline.estimate || null,
      estimated_cost_range: costMatch ? costMatch[0] : null,
      estimated_timeline_weeks: timelineMatch ? `${timelineMatch[1]}-${timelineMatch[2]}` : null,
    },
    // Deliverables / artifacts
    artifacts: [
      ...(pipeline.refined ? [{ type: "product_definition", content: pipeline.refined, stage: "refinement" }] : []),
      ...(pipeline.prd ? [{ type: "prd", content: pipeline.prd, stage: "requirements" }] : []),
      ...(pipeline.tech_spec ? [{ type: "technical_spec", content: pipeline.tech_spec, stage: "architecture" }] : []),
      ...(pipeline.estimate ? [{ type: "cost_estimate", content: pipeline.estimate, stage: "estimation" }] : []),
      ...(pipeline.proto_prompt ? [{ type: "prototype_prompt", content: pipeline.proto_prompt, stage: "prototyping" }] : []),
    ],
    // Impact assessment placeholder
    impact: {
      value_at_stake: null, // To be filled by WAVE users
      confidence_level: pipeline.current_stage >= 5 ? "medium" : "low",
      time_to_value_weeks: timelineMatch ? parseInt(timelineMatch[2]) : null,
    },
  };
}

